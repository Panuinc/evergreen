<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Device -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/device_section_device"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <include layout="@layout/item_info_row"
                    android:id="@+id/rowModel" />
                <include layout="@layout/item_info_row"
                    android:id="@+id/rowAndroid" />
                <include layout="@layout/item_info_row"
                    android:id="@+id/rowBattery" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- RFID -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/device_section_rfid"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <include layout="@layout/item_info_row"
                    android:id="@+id/rowRfidStatus" />
                <include layout="@layout/item_info_row"
                    android:id="@+id/rowRfidFirmware" />
                <include layout="@layout/item_info_row"
                    android:id="@+id/rowRfidHardware" />
                <include layout="@layout/item_info_row"
                    android:id="@+id/rowRfidTemp" />
                <include layout="@layout/item_info_row"
                    android:id="@+id/rowRfidPower" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- App -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/device_section_app"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <include layout="@layout/item_info_row"
                    android:id="@+id/rowAppVersion" />
                <include layout="@layout/item_info_row"
                    android:id="@+id/rowServerUrl" />
                <include layout="@layout/item_info_row"
                    android:id="@+id/rowUser" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
